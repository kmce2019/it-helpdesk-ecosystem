# Application Settings
APP_NAME=District IT Help Desk
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
AGENT_API_KEY=your-agent-api-key-change-this

# Database
DATABASE_URL=postgresql://helpdesk:helpdesk_password@db:5432/helpdesk_db

# SMTP Email Configuration
SMTP_ENABLED=True
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=helpdesk@district.edu
SMTP_FROM_NAME=District IT Help Desk
SMTP_USE_TLS=True

# Google Chat Webhook
GOOGLE_CHAT_ENABLED=True
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE_ID/messages?key=YOUR_KEY&token=YOUR_TOKEN

# CVE / NVD Settings
NVD_API_KEY=
CVE_CHECK_INTERVAL_HOURS=168

# Frontend URL
FRONTEND_URL=http://localhost:3000
