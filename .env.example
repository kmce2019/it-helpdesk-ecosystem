# ─── Backend Configuration ────────────────────────────────────────────────────

SECRET_KEY=your-super-secret-key-change-this-in-production
AGENT_API_KEY=your-agent-api-key-change-this-in-production

# ─── SMTP Email Configuration ─────────────────────────────────────────────────

SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=helpdesk@district.edu

# ─── Google Chat Webhook ─────────────────────────────────────────────────────

GOOGLE_CHAT_ENABLED=False
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE_ID/messages?key=YOUR_KEY&token=YOUR_TOKEN

# ─── CVE / NVD Settings ──────────────────────────────────────────────────────

CVE_CHECK_INTERVAL_HOURS=168

# ─── Frontend Configuration ──────────────────────────────────────────────────

VITE_API_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:4000
